# Logging: silent | events (default) | verbose | debug
LOG_MODE=events

# Auto-append captured events to this file
SAVE_EVENTS=true
EVENTS_FILE=events.json

# Optional: print a rolling summary every N captured events (0 = shutdown only)
LOG_SUMMARY_INTERVAL=0

# Suppress mitmproxy connection noise: error | warn | info | debug
TERMLOG_VERBOSITY=error

# Ignore non-LLM hosts (bing, spotify, instagram, etc.) — passes them through untouched
IGNORE_HOSTS_PATTERN=^(?!.*(claude|anthropic|openai)).*

# Addon-internal domain filter (mitmproxy 12 removed global flow_filter)
FLOW_FILTER=~d claude.ai | ~d anthropic.com | ~d a-api.anthropic.com | ~d chatgpt.com | ~d grok.com
